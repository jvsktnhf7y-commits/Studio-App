                .form-group {{ margin-bottom: 20px; }}
                .form-group label {{ display: block; font-weight: 600; font-size: 0.9em; margin-bottom: 8px; }}
                .form-control, select {{ width: 100%; padding: 12px; border: 1px solid #d2d2d7; border-radius: var(--border-radius-sm); font-size: 1em; box-sizing: border-box; background-color: #fafafa; }}
                .btn-submit {{ background-color: var(--accent-blue); color: white; width: 100%; padding: 12px; border-radius: var(--border-radius-sm); font-size: 1em; font-weight: 600; }}
