@app.post("/login")
def login_post(username: str = Form(...), password: str = Form(...)):
    """Handle login"""
    import json
    import hashlib
    import os
    
    PASSWORD_FILE = "admin_password.json"
    
    # Only admin user for now
    if username != "admin":
        return RedirectResponse(url="/login?error=Invalid username or password", status_code=303)
    
    # Check password from file
    if os.path.exists(PASSWORD_FILE):
        with open(PASSWORD_FILE, 'r') as f:
            data = json.load(f)
            stored_hash = data.get("password_hash", "")
            input_hash = hashlib.sha256(password.encode()).hexdigest()
            if input_hash == stored_hash:
                response = RedirectResponse(url="/", status_code=303)
                response.set_cookie(key="studio_session", value="authenticated", httponly=True, max_age=86400)
                return response
    
    return RedirectResponse(url="/login?error=Invalid username or password", status_code=303)@app.get("/logout")
def logout():
    """Handle logout"""
    response = RedirectResponse(url="/login", status_code=303)
    response.delete_cookie("studio_session")
    return response

# Simple auth middleware
@app.middleware("http")
async def check_auth(request: Request, call_next):
    # Skip auth for login/logout
    if request.url.path in ["/login", "/logout", "/docs", "/openapi.json"]:
        return await call_next(request)
    
    # Check for session cookie
    session = request.cookies.get("studio_session")
    if session == "authenticated":
        return await call_next(request)
    
    # Redirect to login
    return RedirectResponse(url="/login", status_code=303)


