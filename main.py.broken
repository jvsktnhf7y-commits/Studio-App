                .action-bar {{ display: flex; gap: 10px; }}
                button, .btn-shortcut {{ font-family: inherit; border: none; padding: 10px 18px; border-radius: var(--border-radius-sm); font-weight: 600; font-size: 0.9em; cursor: pointer; transition: all 0.15s ease; text-decoration: none; display: inline-block; text-align: center; }}
