# --- PAGE 1: TODAY VIEW ENDPOINT ---
@app.get("/", response_class=HTMLResponse)
def home_dashboard():
    current_day = datetime.now().strftime("%A")
    current_month = datetime.now().strftime("%B %Y")
    events = get_google_calendar_events()
    profiles_map = get_all_profiles()
    paid_count, noshow_count, revenue = calculate_advanced_stats()
    monthly_billing_records = calculate_monthly_statements()
    last_action = get_last_undone_action()

    body = f"""
    <h1>Studio Operations</h1>
    <div class="day-banner">📅 Running Schedule: {current_day}</div>
    
    <div class="stats-bar">
        <div class="stat-card">
            <div class="stat-label">🎼 Lessons Logged</div>
            <div class="stat-value">✅ {paid_count}</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">🚨 No-Shows</div>
            <div class="stat-value" style="color: var(--accent-red);">⏳ {noshow_count}</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">💰 Monthly Revenue</div>
            <div class="stat-value">${revenue:.2f}</div>
        </div>
    </div>

    <h2>📊 Running Ledger Statements ({current_month})</h2>
    <div class="statement-box">
    """
    if not monthly_billing_records:
        body += '<div style="color: var(--text-secondary); text-align:center; padding:10px 0;">No active billing loops calculated in this cycle.</div>'
    else:
        for student, data in monthly_billing_records.items():
            if data['lessons'] == 0 and data['noshows'] == 0 and data['total'] == 0:
                continue
            calculated_balance = round(float(data['total']), 2)
            body += f"""
            <div class="statement-row">
                <span>👤 <b>{student}</b> <span style="color: var(--text-secondary); font-size:0.9em; margin-left:10px;">(Attended: {data['lessons']} | No-Shows: {data['noshows']})</span></span>
                <span style="font-weight: 600;">Due: ${calculated_balance:.2f}</span>
            </div>
            """
    body += "</div><h2>👥 Today's Lesson Roster Feed</h2>"

    if isinstance(events, dict) and "error" in events:
        body += f'<div class="lesson-card" style="color: var(--accent-red); font-weight:600;">Calendar API Alert: {events["error"]}</div>'
    elif not events:
        body += '<div class="lesson-card" style="color: var(--text-secondary); text-align:center; font-style:italic; padding:30px;">All clear! No upcoming calendar slots tracked for today. ☕</div>'
    else:
        for event in events:
            student_name = event.get('summary', 'Unknown Student')
            start_info = event.get('start', {})
            end_info = event.get('end', {})
            start_str = start_info.get('dateTime', start_info.get('date', ''))
            end_str = end_info.get('dateTime', end_info.get('date', ''))
            
            formatted_time = "All Day"
            length_badge = ""
            calendar_minutes = 60
            
            if 'T' in start_str and 'T' in end_str:
                time_part = start_str.split('T')[1][:5]
                try:
                    hr, mn = map(int, time_part.split(':'))
                    ampm = "AM" if hr < 12 else "PM"
                    if hr > 12: hr -= 12
                    elif hr == 0: hr = 12
                    formatted_time = f"{hr}:{mn:02d} {ampm}"
                except Exception:
                    formatted_time = time_part

                try:
                    clean_start = start_str.split('-')[0].split('+')[0]
                    clean_end = end_str.split('-')[0].split('+')[0]
                    duration = datetime.fromisoformat(clean_end) - datetime.fromisoformat(clean_start)
                    calendar_minutes = int(duration.total_seconds() / 60)
                    length_badge = f'<span class="pill length-pill">⏱️ {calendar_minutes} mins</span>'
                except Exception:
                    length_badge = '<span class="pill length-pill">⏱️ 60 mins</span>'

            is_registered = student_name in profiles_map
            mismatch_alert = ""
            
            if is_registered:
                profile = profiles_map[student_name]
                credit_badge = f'<span class="pill credit-pill">🎒 Rollover: {profile["credits"]}</span>' if profile["credits"] > 0 else ""
                rate_badge = f'<span class="pill rate-pill">💵 Rate: ${profile["rate"]:.2f}/hr</span>'
                desc_line = f'<span class="desc-text">📋 <b>Focus:</b> {profile["description"]} <span style="color: var(--text-secondary);">({profile["tier_name"]})</span></span>'
                if calendar_minutes != profile["target_minutes"]:
                    mismatch_alert = f'<span class="pill mismatch-warning">⚠️ Mismatch (Expected {profile["target_minutes"]}m)</span>'
            else:
                credit_badge = '<span class="pill unregistered-warning">⚠️ Profile Offline</span>'
                rate_badge = f'<a href="/students?prefill_name={student_name}" class="btn-shortcut">➕ Create Profile</a>'
                desc_line = '<span class="desc-text" style="color: var(--accent-orange); font-weight: 500;">Click "Create Profile" to sync this identity with your studio database.</span>'

            body += f"""
            <div class="lesson-card">
                <div class="card-header-row">
                    <span class="student">👤 {student_name}</span> {rate_badge} {length_badge} {mismatch_alert} {credit_badge}
                </div>
                {desc_line}
                <span class="time-text">🕒 <b>Session Clock:</b> {formatted_time}</span>
                <div class="action-bar">
                    <form action="/log-attendance" method="post" style="margin:0;">
                        <input type="hidden" name="student" value="{student_name}"><input type="hidden" name="status" value="Attended"><input type="hidden" name="duration_mins" value="{calendar_minutes}">
                        <button type="submit" class="btn-attend">✅ Check-In</button>
                    </form>
                    <form action="/log-attendance" method="post" style="margin:0;">
                        <input type="hidden" name="student" value="{student_name}"><input type="hidden" name="status" value="Teacher Cancelled">
                        <button type="submit" class="btn-cancel">🔄 Cancel</button>
                    </form>
                    <form action="/log-attendance" method="post" style="margin:0;">
                        <input type="hidden" name="student" value="{student_name}"><input type="hidden" name="status" value="No-Show"><input type="hidden" name="duration_mins" value="{calendar_minutes}">
                        <button type="submit" class="btn-noshow">❌ No-Show</button>
                    </form>
                </div>
            </div>
            """

    if last_action:
        body += f"""
        <div class="undo-panel">
            <div style="font-size: 0.95em;">⏮️ <b>Recent Action:</b> <u>{last_action.get('Student','')}</u> set to <i>{last_action.get('Status','')}</i> (${last_action.get('AmountCharged','')})</div>
            <form action="/undo-last-action" method="post" style="margin:0;">
                <input type="hidden" name="target_student" value="{last_action.get('Student','')}"><input type="hidden" name="target_status" value="{last_action.get('Status','')}"><input type="hidden" name="target_charge" value="{last_action.get('AmountCharged','0')}">
                <button type="submit" style="background-color: var(--text-secondary); color:white; padding:6px 12px; font-size:0.85em;">↩️ Undo</button>
            </form>
        </div>
        """
    return get_shared_html_layout("today", body)

# --- PAGE 2: STUDENTS ROSTER ENDPOINT ---
@app.get("/students", response_class=HTMLResponse)
def students_page(prefill_name: str = ""):
    profiles_map = get_all_profiles()
    pricing_tiers = get_pricing_tiers()
    
    body = """
    <h1>Active Student Roster</h1>
    <p style="color: var(--text-secondary); margin-bottom:25px;">Manage local student parameters and onboarding registration records.</p>
    """
    
    if not profiles_map:
        body += '<div class="lesson-card" style="text-align:center; color: var(--text-secondary); font-style:italic;">No student profiles registered in local database yet.</div>'
    else:
        for name, data in profiles_map.items():
            body += f"""
            <div class="lesson-card">
                <div class="card-header-row">
                    <span class="student">👤 {name}</span>
                    <span class="pill rate-pill">💵 Package Rate: ${data['rate']:.2f}/hr</span>
                    <span class="pill length-pill">⏱️ Targets: {data['target_minutes']}m</span>
                    {f"<span class='pill credit-pill'>🎒 Rollover: {data['credits']}</span>" if data['credits'] > 0 else ""}
                </div>
                <span class="desc-text">📋 <b>Focus Notes:</b> {data['description']} <span style="color: var(--text-secondary);">({data['tier_name']})</span></span>
            </div>
            """
            
    body += f"""
    <h2>➕ Register New Student Profile</h2>
    <div class="form-panel">
        <form action="/add-profile" method="post">
            <div class="form-group">
                <label>Student Name</label>
                <input type="text" name="name" class="form-control" placeholder="Match Calendar Subject String Exactly" value="{prefill_name}" required>
            </div>
            <div class="form-group">
                <label>Assigned Pricing Profile Tier Package</label>
                <select name="rate_tier_name" class="form-control">
    """
    for tier, tier_data in pricing_tiers.items():
        body += f'<option value="{tier}">{tier} ({tier_data["minutes"]} mins @ ${tier_data["rate"]:.2f}/hr)</option>'
    body += """
                </select>
            </div>
            <div class="form-group">
                <label>Curriculum Focus / Pedagogical Notes</label>
                <input type="text" name="description" class="form-control" placeholder="e.g. Snare focus, rolling mallet prep" required>
            </div>
            <button type="submit" class="btn-submit">Complete Profile Integration</button>
        </form>
    </div>
    """
    return get_shared_html_layout("students", body)

# --- PAGE 3: RATES & PRICING CONFIG ENDPOINT ---
@app.get("/rates", response_class=HTMLResponse)
def rates_page():
    pricing_tiers = get_pricing_tiers()
    body = """
    <h1>Studio Pricing Configuration</h1>
    <p style="color: var(--text-secondary); margin-bottom:25px;">Define custom lesson lengths and foundational base hourly billing rates.</p>
    <div class="form-panel" style="padding: 10px 24px;">
    """
    idx = 0
    for tier_name, tier_info in pricing_tiers.items():
        body += f"""
        <div id="row-container-{idx}" class="rate-row" style="padding: 12px 0; border-bottom: 1px solid #f2f2f7;">
            <div id="view-mode-{idx}" style="display:flex; flex:1; gap:10px; align-items:center;">
                <div class="static-field" style="flex:2; font-weight:500;">🏷️ {tier_name}</div>
                <div class="static-field" style="max-width:80px; text-align:center; color: var(--accent-blue); font-weight:600;">⏱️ {tier_info['minutes']} m</div>
                <div class="static-field" style="max-width:100px; text-align:center; font-weight:600;">${tier_info['rate']:.2f}/hr</div>
                <button type="button" class="btn-shortcut" onclick="toggleTierRowEdit({idx})">✏️ Edit</button>
            </div>
            <form action="/update-pricing-tier" method="post" id="edit-mode-{idx}" style="display:none; flex:1; gap:10px; align-items:center; margin:0;">
                <input type="hidden" name="old_tier_name" value="{tier_name}">
                <input type="text" name="new_tier_name" value="{tier_name}" class="form-control" style="flex:2;" required>
                <input type="number" name="target_minutes" value="{tier_info['minutes']}" class="form-control" style="width:75px;" required>
                <input type="number" step="0.01" name="hourly_rate" value="{tier_info['rate']:.2f}" class="form-control" style="width:85px;" required>
                <button type="submit" class="btn-shortcut" style="background-color: var(--accent-green);">✅ Save</button>
            </form>
            <form action="/delete-pricing-tier" method="post" style="margin:0;">
                <input type="hidden" name="tier_name" value="{tier_name}">
                <button type="submit" class="btn-shortcut" style="margin:0; background-color: var(--accent-red);">🗑️ Delete</button>
            </form>
        </div>
        """
        idx += 1
    body += """
    </div>
    <h2>⚙️ Add New Pricing Configuration</h2>
    <div class="form-panel">
        <form action="/save-pricing-tier" method="post" class="rate-row" style="margin:0; gap:15px; flex-direction:column; align-items:stretch;">
            <div class="form-group" style="margin:0;">
                <label>Package / Tier Name</label>
                <input type="text" name="tier_name" placeholder="e.g. Advanced Snare Masterclass" class="form-control" required>
            </div>
            <div style="display:flex; gap:15px;">
                <div class="form-group" style="flex:1; margin:0;">
                    <label>Target Lesson Length (Minutes)</label>
                    <input type="number" name="target_minutes" placeholder="e.g. 45" class="form-control" required>
                </div>
                <div class="form-group" style="flex:1; margin:0;">
                    <label>Base Hourly Value ($/hr)</label>
                    <input type="number" step="0.01" name="hourly_rate" placeholder="e.g. 60.00" class="form-control" required>
                </div>
            </div>
            <button type="submit" class="btn-submit" style="background-color: var(--accent-green);">+ Deploy Package Tier</button>
        </form>
    </div>
    """
    return get_shared_html_layout("rates", body)

# --- POST ROUTING MUTATIONS ---
@app.post("/log-attendance")
def log_attendance(student: str = Form(...), status: str = Form(...), duration_mins: int = Form(60)):
    profiles_map = get_all_profiles()
    profile = profiles_map.get(student, {"rate": DEFAULT_RATE, "credits": 0, "description": "", "target_minutes": 60})
    lesson_hours = duration_mins / 60.0
    amount_to_charge = profile["rate"] * lesson_hours
    notes = f"Pro-rated for exactly {duration_mins} mins."
    if status == "Attended":
        if profile["credits"] > 0:
            profiles_map[student]["credits"] -= 1
            amount_to_charge = 0.00
            notes = f"Attended ({duration_mins} mins). Used 1 active rollover studio credit. Charged $0.00."
    elif status == "Teacher Cancelled":
        if student not in profiles_map:
            profiles_map[student] = {"tier_name": "Unknown Package", "rate": DEFAULT_RATE, "target_minutes": 60, "credits": 0, "description": ""}
        profiles_map[student]["credits"] += 1
        amount_to_charge = 0.00
        notes = "Lesson cancelled by Instructor. Added +1 rollover balance credit to profile."
    elif status == "No-Show":
        notes = f"Unexcused student absence. Charged pro-rated booking rate (${profile['rate']:.2f}/hr × {lesson_hours:.2f} hrs)."
    save_all_profiles(profiles_map)
    today_str = datetime.now().strftime("%Y-%m-%d")
    with open(LEDGER_FILE, "a", newline="") as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow([today_str, student, status, f"{amount_to_charge:.2f}", notes])
    return RedirectResponse(url="/", status_code=303)

@app.post("/undo-last-action")
def undo_last_action(target_student: str = Form(...), target_status: str = Form(...), target_charge: float = Form(...)):
    profiles_map = get_all_profiles()
    if target_student in profiles_map:
        if target_status == "Teacher Cancelled" and profiles_map[target_student]["credits"] > 0:
            profiles_map[target_student]["credits"] -= 1
        elif target_status == "Attended" and target_charge == 0.0:
            profiles_map[target_student]["credits"] += 1
    save_all_profiles(profiles_map)
    inverse_charge = -1 * target_charge
    today_str = datetime.now().strftime("%Y-%m-%d")
    with open(LEDGER_FILE, "a", newline="") as csvfile:
        writer = csv.writer(csvfile)
        writer.writerow([today_str, target_student, "Ledger Correction", f"{inverse_charge:.2f}", f"REVERSAL CORE: Safely reversed {target_status} entry mistake."])
    return RedirectResponse(url="/", status_code=303)

@app.post("/save-pricing-tier")
def save_pricing_tier(tier_name: str = Form(...), hourly_rate: float = Form(...), target_minutes: int = Form(60)):
    tiers_map = get_pricing_tiers()
    tiers_map[tier_name] = {"rate": hourly_rate, "minutes": target_minutes}
    with open(PRICING_FILE, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["TierName", "HourlyRate", "TargetMinutes"])
        for name, data in tiers_map.items():
            writer.writerow([name, f"{data['rate']:.2f}", data['minutes']])
    return RedirectResponse(url="/rates", status_code=303)

@app.post("/update-pricing-tier")
def update_pricing_tier(old_tier_name: str = Form(...), new_tier_name: str = Form(...), hourly_rate: float = Form(...), target_minutes: int = Form(60)):
    tiers_map = get_pricing_tiers()
    if old_tier_name in tiers_map:
        del tiers_map[old_tier_name]
    tiers_map[new_tier_name] = {"rate": hourly_rate, "minutes": target_minutes}
    with open(PRICING_FILE, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["TierName", "HourlyRate", "TargetMinutes"])
        for name, data in tiers_map.items():
            writer.writerow([name, f"{data['rate']:.2f}", data['minutes']])
    return RedirectResponse(url="/rates", status_code=303)

@app.post("/delete-pricing-tier")
def delete_pricing_tier(tier_name: str = Form(...)):
    tiers_map = get_pricing_tiers()
    if tier_name in tiers_map:
        del tiers_map[tier_name]
    with open(PRICING_FILE, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["TierName", "HourlyRate", "TargetMinutes"])
        for name, data in tiers_map.items():
            writer.writerow([name, f"{data['rate']:.2f}", data['minutes']])
    return RedirectResponse(url="/rates", status_code=303)

@app.post("/add-profile")
def add_profile(name: str = Form(...), rate_tier_name: str = Form(...), description: str = Form(...)):
    tiers_map = get_pricing_tiers()
    selected_tier = tiers_map.get(rate_tier_name, {"rate": DEFAULT_RATE, "minutes": 60})
    profiles_map = get_all_profiles()
    profiles_map[name] = {
        "tier_name": rate_tier_name,
        "rate": selected_tier["rate"],
        "target_minutes": selected_tier["minutes"],
        "credits": profiles_map.get(name, {}).get("credits", 0),
        "description": description
    }
    save_all_profiles(profiles_map)
    return RedirectResponse(url="/students", status_code=303)

