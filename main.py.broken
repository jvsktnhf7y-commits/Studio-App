                    background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
                    border-bottom: 1px solid rgba(0, 0, 0, 0.05); z-index: 1000;
                    display: flex; justify-content: center; align-items: center;
                }}
                .nav-container {{ width: 100%; max-width: 800px; display: flex; justify-content: space-between; align-items: center; padding: 0 20px; }}
                .nav-brand {{ font-weight: 700; font-size: 1.1em; color: var(--text-primary); }}
                .nav-links {{ display: flex; gap: 6px; }}
                .nav-link {{
                    color: var(--text-secondary); text-decoration: none; font-size: 0.95em; font-weight: 500;
                    padding: 8px 16px; border-radius: 18px; transition: all 0.2s ease;
                }}
                .nav-link:hover {{ color: var(--accent-blue); background: rgba(0, 113, 227, 0.05); }}
                .nav-link.active {{ color: var(--accent-blue); background: rgba(0, 113, 227, 0.08); font-weight: 600; }}
                .container {{ max-width: 800px; margin: 0 auto; }}
                h1 {{ font-size: 2.2em; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 8px; }}
                h2 {{ font-size: 1.4em; font-weight: 600; margin-top: 40px; margin-bottom: 18px; }}
                .day-banner {{ background: rgba(0, 113, 227, 0.06); color: var(--accent-blue); padding: 6px 14px; border-radius: 20px; font-size: 0.85em; font-weight: 600; display: inline-block; margin-bottom: 25px; }}
                .stats-bar {{ display: flex; gap: 16px; margin-bottom: 30px; }}
                .stat-card {{ flex: 1; background: var(--bg-card); padding: 20px; border-radius: var(--border-radius-lg); box-shadow: var(--shadow-sm); }}
                .stat-label {{ font-size: 0.8em; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; }}
                .stat-value {{ font-size: 1.8em; font-weight: 700; margin-top: 6px; }}
                .lesson-card, .form-panel, .statement-box {{ background: var(--bg-card); padding: 24px; border-radius: var(--border-radius-lg); box-shadow: var(--shadow-sm); margin-bottom: 16px; }}
                .card-header-row {{ display: flex; align-items: center; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }}
                .student {{ font-size: 1.3em; font-weight: 700; }}
                .pill {{ font-size: 0.75em; font-weight: 600; padding: 4px 10px; border-radius: 12px; }}
                .rate-pill {{ background: #f2f2f7; color: var(--text-primary); }}
                .length-pill {{ background: #e8f0fe; color: #1a73e8; }}
                .credit-pill {{ background: #e6f4ea; color: #137333; }}
                .unregistered-warning {{ background: #fff3cd; color: #856404; }}
