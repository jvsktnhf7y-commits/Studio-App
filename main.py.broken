    <html>
        <head>
            <title>Studio Management Suite</title>
            <style>
                :root {{
                    --bg-main: #f5f5f7;
                    --bg-card: #ffffff;
                    --text-primary: #1d1d1f;
                    --text-secondary: #6e6e73;
                    --accent-blue: #0071e3;
                    --accent-green: #34c759;
                    --accent-orange: #ff9500;
                    --accent-red: #ff3b30;
                    --border-radius-lg: 16px;
                    --border-radius-sm: 8px;
                    --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
